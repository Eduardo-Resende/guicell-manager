# ─── Modelo de variáveis de ambiente para PRODUÇÃO ────────────────────────────
# Copie este arquivo para .env no VPS e preencha os valores reais.
# NUNCA commite o arquivo .env com senhas reais!

# Servidor
PORT=3001
NODE_ENV=production

# Banco de Dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=guicell_manager
DB_USER=guicell_app
DB_PASS=TROQUE_PELA_SENHA_DO_BANCO

# Autenticação JWT
JWT_SECRET=TROQUE_POR_UM_SECRET_LONGO_E_ALEATORIO
JWT_EXPIRES_IN=8h

# CORS — URL do frontend (IP ou domínio)
FRONTEND_URL=http://179.197.228.65
